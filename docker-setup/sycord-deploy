#!/bin/bash
# ==============================================================================
# SYCORD CONTAINER DEPLOYER
# Runs inside the container to package and publish the build to sycord.site.
# ==============================================================================

set -e

echo "🚀 [Sycord Deploy] Preparing Next.js standalone production build..."

# Ensure we are in the workspace directory
cd /workspace

# Trigger Next.js build if not already run
if [ ! -d ".next" ]; then
  echo "⚠️ Build directory (.next) not found. Compiling now..."
  npm run build
fi

# Pack the build into a lightweight tarball
echo "📦 [Sycord Deploy] Packaging build files..."
tar -czf "/deployments/${WORKSPACE_ID}-build.tar.gz" .next public package.json

# Trigger the host CDN receiver script to unpack and publish
echo "🌐 [Sycord Deploy] Publishing to Edge CDN (sycord.site)..."
# In production, we run this on the host via an internal trigger or shared folder command
touch "/deployments/${WORKSPACE_ID}.trigger"

echo "✅ [Sycord Deploy] Site successfully published!"